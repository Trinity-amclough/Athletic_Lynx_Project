generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id          Int     @id @default(autoincrement())
  email       String  @unique
  phone       String
  name        String
  age         Int
  city        String
  position    String
  // profilePhoto    String?
  createdAt   DateTime @default(now())
  history     History?
}

model History {
  id                Int     @id
  description       String
  user              User   @relation(fields: [userId], references: [id]) 
  userId            Int    @unique    
}

